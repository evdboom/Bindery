{
  "name": "bindery-mcp",
  "version": "1.0.0",
  "description": "MCP server for Bindery markdown book projects — chapter navigation, search, typography formatting, and export.",
  "main": "out/index.js",
  "files": [
    "out"
  ],
  "bin": {
    "bindery-mcp": "./out/index.js"
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "npm run compile",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --reporter=verbose --reporter=json --outputFile=test-results.json",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "mcp",
    "markdown",
    "book",
    "writing",
    "bindery"
  ],
  "author": "Erik van der Boom",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "fflate": "^0.8.2",
    "minisearch": "^7.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "6.0.3",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
