{
  "name": "bindery-mcp",
  "version": "0.1.0",
  "description": "MCP server for Bindery markdown book projects — chapter navigation, search, typography formatting, and export.",
  "main": "out/index.js",
  "bin": {
    "bindery-mcp": "./out/index.js"
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "npm run compile",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["mcp", "markdown", "book", "writing", "bindery"],
  "author": "Erik van der Boom",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "minisearch": "^7.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
